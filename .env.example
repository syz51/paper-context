PAPER_CONTEXT_DATABASE__URL=postgresql+psycopg://paper_context:paper_context@localhost:5433/paper_context
PAPER_CONTEXT_STORAGE__ROOT_PATH=./var/artifacts
PAPER_CONTEXT_LOG_LEVEL=INFO
PAPER_CONTEXT_QUEUE__NAME=document_ingest
PAPER_CONTEXT_QUEUE__VISIBILITY_TIMEOUT_SECONDS=300
PAPER_CONTEXT_QUEUE__MAX_POLL_SECONDS=5
PAPER_CONTEXT_QUEUE__POLL_INTERVAL_MS=250
PAPER_CONTEXT_RUNTIME__API_HOST=0.0.0.0
PAPER_CONTEXT_RUNTIME__API_PORT=8000
PAPER_CONTEXT_RUNTIME__MCP_HOST=0.0.0.0
PAPER_CONTEXT_RUNTIME__MCP_PORT=8001
PAPER_CONTEXT_RUNTIME__WORKER_IDLE_SLEEP_SECONDS=1.0
PAPER_CONTEXT_PROVIDERS__VOYAGE_MODEL=voyage-4-large
PAPER_CONTEXT_PROVIDERS__RERANKER_MODEL=zerank-2
PAPER_CONTEXT_PROVIDERS__INDEX_VERSION=mvp-v1
PAPER_CONTEXT_PROVIDERS__VOYAGE_API_KEY=
PAPER_CONTEXT_PROVIDERS__ZERO_ENTROPY_API_KEY=
PAPER_CONTEXT_PROVIDERS__OPENALEX_API_KEY=
