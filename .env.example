# Host-run commands use localhost:5433; Docker Compose services override this to db:5432.
# In Compose, the app and worker mount a persistent artifact volume at /var/lib/paper-context/artifacts.
PAPER_CONTEXT_DATABASE__URL=postgresql+psycopg://paper_context:paper_context@localhost:5433/paper_context
# Production requires these to be set explicitly when PAPER_CONTEXT_ENVIRONMENT=production.
# PAPER_CONTEXT_DATABASE__SSL_MODE=require
# PAPER_CONTEXT_DATABASE__CONNECT_TIMEOUT_SECONDS=10
# PAPER_CONTEXT_DATABASE__STATEMENT_TIMEOUT_MS=30000
# PAPER_CONTEXT_DATABASE__LOCK_TIMEOUT_MS=5000
# PAPER_CONTEXT_DATABASE__IDLE_IN_TRANSACTION_SESSION_TIMEOUT_MS=15000
# PAPER_CONTEXT_DATABASE__APPLICATION_NAME=paper-context
# PAPER_CONTEXT_DATABASE__POOL_SIZE=10
# PAPER_CONTEXT_DATABASE__MAX_OVERFLOW=10
# PAPER_CONTEXT_DATABASE__POOL_TIMEOUT_SECONDS=30
# PAPER_CONTEXT_DATABASE__POOL_RECYCLE_SECONDS=1800
PAPER_CONTEXT_STORAGE__ROOT_PATH=./var/artifacts
# For Compose, override the storage root to /var/lib/paper-context/artifacts so it matches the persistent volume.
PAPER_CONTEXT_LOG_LEVEL=INFO
PAPER_CONTEXT_QUEUE__NAME=document_ingest
PAPER_CONTEXT_QUEUE__VISIBILITY_TIMEOUT_SECONDS=300
PAPER_CONTEXT_QUEUE__MAX_POLL_SECONDS=5
PAPER_CONTEXT_QUEUE__POLL_INTERVAL_MS=250
PAPER_CONTEXT_RUNTIME__APP_HOST=0.0.0.0
PAPER_CONTEXT_RUNTIME__APP_PORT=8000
PAPER_CONTEXT_RUNTIME__WORKER_IDLE_SLEEP_SECONDS=1.0
PAPER_CONTEXT_PROVIDERS__VOYAGE_MODEL=voyage-4-large
PAPER_CONTEXT_PROVIDERS__RERANKER_MODEL=zerank-2
PAPER_CONTEXT_PROVIDERS__INDEX_VERSION=mvp-v1
# Leave provider keys empty for local development. Set them explicitly before enabling provider-backed enrichment or retrieval.
PAPER_CONTEXT_PROVIDERS__VOYAGE_API_KEY=
PAPER_CONTEXT_PROVIDERS__ZERO_ENTROPY_API_KEY=
PAPER_CONTEXT_PROVIDERS__OPENALEX_API_KEY=
PAPER_CONTEXT_PROVIDERS__SEMANTIC_SCHOLAR_API_KEY=
